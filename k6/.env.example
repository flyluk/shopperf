# BASE_URL — your app URL reachable from this machine
# Get it with: ssh dev-vm1.test.local "kubectl get svc -n shopperf"
BASE_URL=http://<your-app-url>

# Prometheus remote write — direct to cluster (no SSH tunnel)
# One-time setup: .\scripts\expose-prometheus.ps1
# Then use the LoadBalancer IP (same 192.168.1.x subnet as Grafana):
PROMETHEUS_RW_URL=http://<prometheus-external-ip>:9090/api/v1/write

# Grafana UI: http://192.168.1.52  (import dashboard ID 19665 for k6)

# Each VU registers: k6user-{runId}-vu{N}@example.com (prefix derived from TEST_RUN_ID)
TEST_EMAIL_PREFIX_BASE=k6user
TEST_PASSWORD=k6pass123
TEST_EMAIL_DOMAIN=example.com
# Optional: fixed run id; otherwise a timestamp is used per run (and embedded in email prefix)
# TEST_RUN_ID=20260628-001

# Load profile — start with 5 VUs; raise only if the app keeps p95 under 2s
K6_VUS=5
K6_RAMP_UP=5s
K6_HOLD=25s
K6_RAMP_DOWN=5s
K6_SLEEP=0
K6_HTTP_TIMEOUT=10s
# add_remove = add + delete (restores stock). add = stock depletes → many 400 failures.
K6_CART_MODE=add_remove
# false = reuse TCP (faster). true = new connection per request (use if stale-socket hangs).
K6_NO_CONNECTION_REUSE=false
# Retry cart add/delete once on HTTP timeout (status 0).
K6_CART_RETRIES=1

# http_req_duration thresholds (ms) — set to "off" to disable a stat
K6_THRESHOLD_HTTP_AVG_MS=off
K6_THRESHOLD_HTTP_MIN_MS=off
K6_THRESHOLD_HTTP_MAX_MS=off
K6_THRESHOLD_HTTP_P95_MS=2000
K6_THRESHOLD_HTTP_P99_MS=5000

# shop_iteration_ms thresholds (ms)
K6_THRESHOLD_ITER_AVG_MS=off
K6_THRESHOLD_ITER_MIN_MS=off
K6_THRESHOLD_ITER_MAX_MS=off
K6_THRESHOLD_ITER_P95_MS=2000
K6_THRESHOLD_ITER_P99_MS=5000

# Stats exported to Prometheus/Grafana for trend metrics
K6_PROMETHEUS_RW_TREND_STATS=avg,med,p(95)
